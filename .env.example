OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── 회원 DB 저장 (Render 무료는 Persistent Disk 없음 → 아래 중 하나) ──
#
# 방법 A) Supabase Storage (무료) — 권장
#   1. https://supabase.com 에서 무료 프로젝트 생성
#   2. Storage → New bucket → 이름: nasaro-backups (Private)
#   3. Project Settings → API → service_role key 복사 (비밀키!)
#   4. Render Environment에 아래 3개 추가:
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_DB_BUCKET=nasaro-backups
#
# 방법 B) Render 유료 + Persistent Disk
#   Disks → Mount Path /var/data → NASAROAI_DB_PATH=/var/data/nasaroai.db
# NASAROAI_DB_PATH=/var/data/nasaroai.db
