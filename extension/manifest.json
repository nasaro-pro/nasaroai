{
  "manifest_version": 3,
  "name": "ArenaX 에이전트",
  "version": "1.1.0",
  "description": "사용자가 보고 있는 바로 그 탭을 ArenaX 에이전트가 직접 조작합니다 (chrome.debugger 기반).",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "ArenaX 에이전트 열기"
  }
}
