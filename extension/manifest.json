{
  "manifest_version": 3,
  "name": "ArenaX 에이전트",
  "version": "1.0.0",
  "description": "어떤 사이트에서든 ArenaX 웹 에이전트를 사용할 수 있는 사이드 패널",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "ArenaX 에이전트 열기"
  }
}
